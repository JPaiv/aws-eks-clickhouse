{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(task --list)",
      "Bash(task doctor)",
      "Bash(task tm:list*)",
      "Bash(task tm:generate*)",
      "Bash(task fmt*)",
      "Bash(task lint*)",
      "Bash(task sec*)",
      "Bash(task docs*)",
      "Bash(task validate*)",
      "Bash(task check*)",
      "Bash(task plan*)",
      "Bash(task output*)",
      "Bash(task aws:whoami*)",
      "Bash(task k8s:nodes*)",
      "Bash(task k8s:pods*)",
      "Bash(tofu fmt*)",
      "Bash(tofu validate*)",
      "Bash(tofu version*)",
      "Bash(tofu show*)",
      "Bash(tofu output*)",
      "Bash(tofu providers*)",
      "Bash(terramate list*)",
      "Bash(terramate fmt*)",
      "Bash(terramate debug*)",
      "Bash(terramate version*)",
      "Bash(terramate generate*)",
      "Bash(tflint*)",
      "Bash(trivy*)",
      "Bash(terraform-docs*)",
      "Bash(aws sts get-caller-identity*)",
      "Bash(aws sso login*)",
      "Bash(aws eks describe-cluster*)",
      "Bash(aws eks list-clusters*)",
      "Bash(aws eks list-nodegroups*)",
      "Bash(aws ec2 describe-*)",
      "Bash(aws s3 ls*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(kubectl top*)",
      "Bash(kubectl api-resources*)",
      "Bash(kubectl explain*)",
      "Bash(kubectl config get-contexts*)",
      "Bash(kubectl config current-context*)",
      "Bash(helm list*)",
      "Bash(helm status*)",
      "Bash(helm get*)",
      "Bash(helm show*)",
      "Bash(helm search*)",
      "Bash(helm repo list*)",
      "Bash(helm template*)",
      "Bash(argocd app list*)",
      "Bash(argocd app get*)",
      "Bash(argocd app diff*)",
      "Bash(argocd app history*)",
      "Bash(argocd app manifests*)",
      "Bash(argocd version*)",
      "Bash(argocd cluster list*)",
      "Bash(argocd repo list*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote -v)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(jq *)",
      "Bash(yq *)"
    ],
    "deny": [
      "Bash(task apply*)",
      "Bash(task destroy*)",
      "Bash(task nuke*)",
      "Bash(tofu apply*)",
      "Bash(tofu destroy*)",
      "Bash(tofu import*)",
      "Bash(tofu taint*)",
      "Bash(tofu untaint*)",
      "Bash(tofu force-unlock*)",
      "Bash(tofu state rm*)",
      "Bash(tofu state push*)",
      "Bash(cloud-nuke*)",
      "Bash(aws sso logout*)",
      "Read(./.devcontainer/devcontainer.env)",
      "Read(./**/*.tfstate)",
      "Read(./**/*.tfstate.*)",
      "Read(./**/*.tfvars)",
      "Read(./**/kubeconfig)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qE '(^|[|;&[:space:]])(tofu|terraform)[[:space:]]+(apply|destroy|import|taint|force-unlock)|[[:space:]]state[[:space:]]+(rm|push|replace-provider)|cloud-nuke|(^|[|;&[:space:]])task[[:space:]]+(apply|destroy|nuke)|kubectl[[:space:]]+(delete|drain|apply|patch)|helm[[:space:]]+(uninstall|delete|rollback|install|upgrade)|argocd[[:space:]]+app[[:space:]]+(sync|delete|rollback|set|patch)' && printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Mutates infrastructure, state, or the cluster. Under GitOps (ADR-0009) cluster changes should go through Git, not an imperative command.\"}}' || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
