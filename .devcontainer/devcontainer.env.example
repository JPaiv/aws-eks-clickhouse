# Devcontainer environment — copy to devcontainer.env and fill in.
#
#   cp .devcontainer/devcontainer.env.example .devcontainer/devcontainer.env
#
# devcontainer.env is git-ignored and is created automatically (from this file)
# on first container start. It is passed to `docker run --env-file`, so:
#   - no quotes, no `export`, no variable interpolation — values are literal
#   - a rebuild is not needed after editing, but a container restart is
#
# Nothing is read from the host's ~/.aws; post-start.sh generates the whole
# AWS profile from these values.

# ---- AWS ---------------------------------------------------------------------
AWS_PROFILE=clickhouse
AWS_REGION=eu-north-1

# IAM Identity Center (SSO). Leave the placeholders in place to skip AWS setup
# entirely — post-start.sh detects them and configures nothing.
AWS_SSO_START_URL=https://your-sso-portal.awsapps.com/start
AWS_SSO_REGION=eu-north-1
AWS_SSO_ACCOUNT_ID=123456789012
AWS_SSO_ROLE_NAME=AdministratorAccess
AWS_SSO_SESSION=sso

# Alternative to SSO: static credentials. If AWS_ACCESS_KEY_ID is set, the SSO
# values above are ignored and the AWS CLI picks these up directly.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Stack -------------------------------------------------------------------
# Cluster name and remote-state bucket, consumed by Taskfile.yml.
# CLUSTER_NAME follows the null-label scheme (ADR-0011).
CLUSTER_NAME=per-en1-admin-ack
# Set to the `state_bucket` output of `task apply STACK=stacks/bootstrap/state`
# (ADR-0010). Until then, lifecycle tasks other than that first apply fail.
TF_STATE_BUCKET=
